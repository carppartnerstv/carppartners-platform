# =====================================================================
# Variables de entorno del backend — copia a backend/.env y rellena.
# NUNCA subas el .env real al repositorio (está en .gitignore).
# =====================================================================

NODE_ENV=development
PORT=3001

PUBLIC_URL=https://carppartners.tv
# Orígenes permitidos por CORS (separados por coma)
CORS_ORIGINS=https://carppartners.tv,http://localhost:3000

# --- Base de datos (la genera setup-vps.sh) --------------------------
DATABASE_URL=postgresql://carp:CAMBIA_ESTO@localhost:5432/carp_partners
DB_POOL_MAX=10

# --- Redis -----------------------------------------------------------
REDIS_URL=redis://localhost:6379

# --- JWT (genera con: openssl rand -hex 48) --------------------------
JWT_ACCESS_SECRET=genera_un_secreto_largo_aqui
JWT_REFRESH_SECRET=genera_otro_secreto_distinto_aqui
JWT_ACCESS_TTL=24h
JWT_REFRESH_TTL=30d

# --- Stripe ----------------------------------------------------------
STRIPE_SECRET_KEY=sk_live_o_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Identificación del plan por PRODUCTO (lo que ya tienes):
STRIPE_PRODUCT_ANNUAL=prod_UiJ29aTCgFXshA
STRIPE_PRODUCT_MONTHLY=prod_UiJ1iulHEeHC0p
# Opcional: por PRECIO (respaldo). Resuélvelos con scripts/resolve-stripe-prices.js
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_ANNUAL=

# --- Vimeo (Pro/Business con Domain Privacy) -------------------------
# Opción A (recomendada en producción): Personal Access Token con scopes
# que permitan leer archivos de vídeo privados (play.hls.link).
VIMEO_ACCESS_TOKEN=
# Opción B: client_id + client_secret (el backend obtiene el token solo;
# OJO: client_credentials solo da scope público — ver nota en services/vimeo.js)
VIMEO_CLIENT_ID=
VIMEO_CLIENT_SECRET=
